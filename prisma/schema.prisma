// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// JobBoard.slug is the single source of truth linking JobPosting.source to JobBoard records
model JobBoard {
  id          Int          @id @default(autoincrement())
  name        String
  slug        String       @unique
  baseUrl     String
  category    String       @default("general")
  description String?
  active               Boolean      @default(true)
  lastScraped          DateTime?
  lastScrapedCount     Int?
  lastError            String?
  consecutiveFailures  Int          @default(0)
  postings             JobPosting[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model JobPosting {
  id          Int       @id @default(autoincrement())
  title       String
  company     String
  location    String?
  remote      Boolean   @default(false)
  description String?
  url         String    @unique
  source      String
  jobBoard    JobBoard  @relation(fields: [source], references: [slug])
  salary      String?
  postedAt    DateTime?
  scrapedAt   DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Pattern {
  id        Int      @id @default(autoincrement())
  keyword   String
  category  String
  count     Int      @default(0)
  period    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([keyword, period])
}

model Top100Team {
  id        Int      @id @default(autoincrement())
  name      String
  brokerage String?
  location  String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Singleton row (id always = 1) — stores global app configuration
model Settings {
  id               Int      @id @default(1)
  scrapeFrequency  String?  // "6h" | "12h" | "daily" | "weekly" | null = manual only
  emailDigest      Boolean  @default(false)
  emailRecipients  String?  // comma-separated emails
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Stores the full Gemini hiring-intelligence analysis result after each scrape
model Analysis {
  id        Int      @id @default(autoincrement())
  data      Json
  createdAt DateTime @default(now())
}
